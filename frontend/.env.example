# Copy to .env and fill in with the outputs printed by `cd infra && npm run deploy`.
# All of these are safe to expose in a browser (public Cognito + API identifiers).

VITE_AWS_REGION=us-east-1
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
VITE_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
